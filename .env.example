# FactoTips — variables de entorno
# Copia este archivo a .env.local para desarrollo

# DIGEMID (Observatorio de Precios de Medicamentos)
DIGEMID_BASE_URL=https://ms-opm.minsa.gob.pe/msopmcovid
DIGEMID_ORIGIN=https://opm-digemid.minsa.gob.pe

# URL pública del sitio (Open Graph / metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL (Coolify FACTOSYS PERU → postgresql-db → factotips_db)
# Puerto público Coolify: 5433 (no usar el Postgres de la tienda / :5432)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5433/factotips_db

# factotips-py (Kit PDF — merge/split/compress; servicio interno)
# Local: http://127.0.0.1:8000 — Coolify: http://factotips-py:8000 (red interna)
FACTOTIPS_PY_URL=http://127.0.0.1:8000
FACTOTIPS_PY_API_KEY=

# Rate limit distribuido (opcional — multi-instancia en producción)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
